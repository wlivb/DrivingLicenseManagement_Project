<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<connectionStrings>
		<add name="DefaultConnection"
             connectionString="Server=.;Database=DVLD;Integrated Security=True;"
             providerName="System.Data.SqlClient" />
	</connectionStrings>

	<appSettings>
		<add key="ProjectName" value="DVLD_Project" />
	</appSettings>
</configuration>